            {onExit && (
              <IconBtn onClick={onExit} tone="dark" title="خروج">
                خروج
              </IconBtn>
            )}
          </div>
        </div>

        <div className="mt-2 flex items-center justify-between gap-2 flex-wrap">
          <div className="flex items-center gap-2 flex-wrap">
            <TabPill
              active={tabKey === "daily"}
              onClick={() => setTabSafe("daily")}
            >
