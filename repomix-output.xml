                          window.open(`tel:${activeMsg.phone}`, "_self");
                        }}
                        title="اتصال"
                      >
                        📞 اتصال
                      </Btn>
                    </div>
                  </div>
                </div>
              </div>

              <div className="mt-2 flex items-center gap-2 flex-wrap">
                <Btn
                  disabled={!activeMsg.phone}
                  onClick={() => {
                    const link = whatsappLink(
