// src/components/services/ServiceModal.jsx
import React, { useEffect, useMemo, useRef, useState } from "react";
import {
  CheckCircle2,
  MapPin,
  MessageCircle,
  Minus,
  Plus,
  Ruler,
  X,
} from "lucide-react";
import { useLanguage } from "../../context/LanguageContext";
import { serviceDetails } from "./serviceDetailsData";

const getText = (lang, values) => {
  if (lang === "he") return values.he;
  if (lang === "en") return values.en;

  return values.ar;
};

const CARPET_PRICE_OPTIONS = {
  measurements: "measurements",
  meterPrice: "meterPrice",
  onSiteMeasure: "onSiteMeasure",
};

export default function ServiceModal({
  isOpen,
  onClose,
  selected,
  onOrderNow,
}) {
  const { lang, t, dir } = useLanguage();

  const [isVisible, setIsVisible] = useState(false);
  const [isClosing, setIsClosing] = useState(false);
  const [dragOffset, setDragOffset] = useState(0);

  const [location, setLocation] = useState("");
  const [quantity, setQuantity] = useState(1);
  const [carpetPriceOption, setCarpetPriceOption] = useState("");
  const [showErrors, setShowErrors] = useState(false);

  const startYRef = useRef(null);
  const isDraggingRef = useRef(false);
  const locationInputRef = useRef(null);

  const details = useMemo(() => {
    if (!selected) return null;

    return serviceDetails?.[selected.id] || null;
  }, [selected]);

  const firstCard = details?.cards?.[0] || null;

  const isSofa = selected?.id === "sofa";
  const isCarpet = selected?.id === "carpet";
  const showsQuantity = isSofa || isCarpet;

  useEffect(() => {
    if (!isOpen) {
      setIsVisible(false);
      setIsClosing(false);
      setDragOffset(0);
      return undefined;
    }

    setIsClosing(false);
    setDragOffset(0);

    const frame = window.requestAnimationFrame(() => {
      setIsVisible(true);
    });

    return () => {
      window.cancelAnimationFrame(frame);
    };
  }, [isOpen]);

  useEffect(() => {
    setLocation("");
    setQuantity(selected?.id === "carpet" ? "" : 1);
    setCarpetPriceOption("");
    setShowErrors(false);
  }, [selected?.id]);

  useEffect(() => {
    if (!isOpen) return undefined;

    const previousOverflow = document.body.style.overflow;
    document.body.style.overflow = "hidden";

    return () => {
      document.body.style.overflow = previousOverflow;
    };
  }, [isOpen]);

  useEffect(() => {
    if (!isOpen) return undefined;

    const handleKeyDown = (event) => {
      if (event.key === "Escape") {
        closeModal();
      }
    };

    window.addEventListener("keydown", handleKeyDown);

    return () => {
      window.removeEventListener("keydown", handleKeyDown);
    };
  });

  if (!isOpen || !selected) return null;

  const title =
    details?.[
      lang === "ar" ? "title_ar" : lang === "he" ? "title_he" : "title_en"
    ] ||
    t?.[selected.titleKey] ||
    selected.id;

  const description =
    details?.[
      lang === "ar"
        ? "subtitle_ar"
        : lang === "he"
          ? "subtitle_he"
          : "subtitle_en"
    ] ||
    t?.[selected.descriptionKey] ||
    "";

  const includes =
    (lang === "ar"
      ? firstCard?.features_ar
      : lang === "he"
        ? firstCard?.features_he
        : firstCard?.features_en) || [];

  const closeText = getText(lang, {
    ar: "إغلاق",
    he: "סגירה",
    en: "Close",
  });

  const includesTitle = getText(lang, {
    ar: "ماذا تشمل الخدمة؟",
    he: "מה כולל השירות?",
    en: "What does the service include?",
  });

  const orderDetailsTitle = getText(lang, {
    ar: "تفاصيل طلبك",
    he: "פרטי הבקשה",
    en: "Your request details",
  });

  const orderDetailsSubtitle = getText(lang, {
    ar: "أدخل المعلومات المناسبة لك، وبعدها سيفتح واتساب برسالة جاهزة.",
    he: "מלאו את הפרטים המתאימים לכם ולאחר מכן WhatsApp ייפתח עם הודעה מוכנה.",
    en: "Enter the relevant details, then WhatsApp will open with a ready message.",
  });

  const locationLabel = getText(lang, {
    ar: "البلدة",
    he: "יישוב",
    en: "Town",
  });

  const locationRequired = getText(lang, {
    ar: "مطلوب",
    he: "חובה",
    en: "Required",
  });

  const optionalText = getText(lang, {
    ar: "اختياري",
    he: "אופציונלי",
    en: "Optional",
  });

  const locationPlaceholder = getText(lang, {
    ar: "مثال: عكا",
    he: "לדוגמה: עכו",
    en: "Example: Acre",
  });

  const locationHint = getText(lang, {
    ar: "الخدمة متاحة في مناطق الشمال والمركز فقط.",
    he: "השירות זמין באזורי הצפון והמרכז בלבד.",
    en: "Service is available in northern and central areas only.",
  });

  const locationError = getText(lang, {
    ar: "اكتب اسم البلدة لإكمال الطلب.",
    he: "יש להזין את שם היישוב להמשך.",
    en: "Enter your town to continue.",
  });

  const sofaQuantityLabel = getText(lang, {
    ar: "عدد مقاعد الكنب",
    he: "מספר מושבי הספה",
    en: "Number of sofa seats",
  });

  const carpetQuantityLabel = getText(lang, {
    ar: "عدد السجاد",
    he: "מספר השטיחים",
    en: "Number of carpets",
  });

  const quantityLabel = isSofa ? sofaQuantityLabel : carpetQuantityLabel;

  const sofaQuantityHint = getText(lang, {
    ar: "احسب مجموع المقاعد التي تريد تنظيفها.",
    he: "יש להזין את מספר המושבים הכולל שתרצו לנקות.",
    en: "Enter the total number of seats you want cleaned.",
  });

  const carpetQuantityHint = getText(lang, {
    ar: "يمكنك إضافة عدد السجاد، أو تركه فارغًا والمتابعة.",
    he: "אפשר להוסיף את מספר השטיחים או להשאיר ריק ולהמשיך.",
    en: "You can enter the number of carpets or leave it empty.",
  });

  const quantityHint = isSofa ? sofaQuantityHint : carpetQuantityHint;

  const sofaQuantityError = getText(lang, {
    ar: "حدد عدد مقاعد الكنب لإكمال الطلب.",
    he: "יש לבחור את מספר מושבי הספה להמשך.",
    en: "Enter the number of sofa seats to continue.",
  });

  const carpetPricingTitle = getText(lang, {
    ar: "كيف تريد معرفة السعر؟",
    he: "איך תרצו לקבל מחיר?",
    en: "How would you like to get the price?",
  });

  const carpetPricingSubtitle = getText(lang, {
    ar: "هذه الخيارات اختيارية، ويمكنك المتابعة بدون اختيار.",
    he: "האפשרויות האלו אינן חובה, ואפשר להמשיך ללא בחירה.",
    en: "These options are optional. You can continue without choosing one.",
  });

  const measurementsTitle = getText(lang, {
    ar: "أعرف القياسات وسأرسلها",
    he: "אני יודע/ת את המידות ואשלח אותן",
    en: "I know the measurements",
  });

  const measurementsDescription = getText(lang, {
    ar: "سأرسل طول وعرض كل سجادة عبر واتساب.",
    he: "אשלח את האורך והרוחב של כל שטיח ב-WhatsApp.",
    en: "I will send the length and width of each carpet on WhatsApp.",
  });

  const meterPriceTitle = getText(lang, {
    ar: "أريد معرفة سعر المتر",
    he: "אני רוצה לדעת את המחיר למטר",
    en: "I want the price per meter",
  });

  const meterPriceDescription = getText(lang, {
    ar: "سأسأل عن سعر المتر قبل إرسال القياسات.",
    he: "אשאל על המחיר למטר לפני שליחת המידות.",
    en: "I would like to ask about the price per meter first.",
  });

  const onSiteMeasureTitle = getText(lang, {
    ar: "لا أعرف القياسات",
    he: "אני לא יודע/ת את המידות",
    en: "I do not know the measurements",
  });

  const onSiteMeasureDescription = getText(lang, {
    ar: "أحتاج أن يتم قياس السجاد في الموقع.",
    he: "אני צריך/ה מדידה של השטיחים במקום.",
    en: "I need the carpets to be measured at my location.",
  });

  const clearChoiceText = getText(lang, {
    ar: "إلغاء الاختيار",
    he: "ביטול הבחירה",
    en: "Clear selection",
  });

  const contactText = getText(lang, {
    ar: "متابعة الطلب عبر واتساب",
    he: "המשך הבקשה ב-WhatsApp",
    en: "Continue through WhatsApp",
  });

  const swipeHint = getText(lang, {
    ar: "اسحب للأسفل للإغلاق",
    he: "החליקו למטה לסגירה",
    en: "Swipe down to close",
  });

  const sofaPhotosHint = getText(lang, {
    ar: "بعد فتح واتساب، أرسل صور الكنب أو فرشات النوم لتحديد السعر والموعد.",
    he: "לאחר פתיחת WhatsApp, שלחו תמונות של הספות או המזרנים לצורך קביעת המחיר והמועד.",
    en: "After WhatsApp opens, send photos of the sofas or mattresses so the price and appointment can be confirmed.",
  });

  const carpetHint = getText(lang, {
    ar: "عدد السجاد وطريقة معرفة السعر اختياريان، ويمكنك الاتفاق على باقي التفاصيل عبر واتساب.",
    he: "מספר השטיחים ואפשרות התמחור הם אופציונליים, ואת שאר הפרטים אפשר לסכם ב-WhatsApp.",
    en: "The carpet count and pricing option are optional. The remaining details can be discussed on WhatsApp.",
  });

  const generalHint = getText(lang, {
    ar: "بعد فتح واتساب، أرسل الصور والتفاصيل اللازمة لإكمال الطلب.",
    he: "לאחר פתיחת WhatsApp, שלחו תמונות ופרטים להשלמת הבקשה.",
    en: "After WhatsApp opens, send the necessary photos and details to complete the request.",
  });

  const normalizedLocation = location.trim();

  const isLocationValid = normalizedLocation.length >= 2;

  const sofaQuantityNumber = Number(quantity);

  const isSofaQuantityValid =
    !isSofa ||
    (Number.isInteger(sofaQuantityNumber) &&
      sofaQuantityNumber >= 1 &&
      sofaQuantityNumber <= 99);

  const carpetQuantityNumber =
    quantity === "" || quantity === null ? null : Number(quantity);

  const isCarpetQuantityValid =
    !isCarpet ||
    carpetQuantityNumber === null ||
    (Number.isInteger(carpetQuantityNumber) &&
      carpetQuantityNumber >= 1 &&
      carpetQuantityNumber <= 99);

  const isFormValid =
    isLocationValid && isSofaQuantityValid && isCarpetQuantityValid;

  const closeModal = () => {
    if (isClosing) return;

    setIsClosing(true);
    setIsVisible(false);
    setDragOffset(0);

    window.setTimeout(() => {
      onClose?.();
      setIsClosing(false);
    }, 260);
  };

  const handleTouchStart = (event) => {
    const touch = event.touches?.[0];

    if (!touch) return;

    startYRef.current = touch.clientY;
    isDraggingRef.current = true;
  };

  const handleTouchMove = (event) => {
    if (!isDraggingRef.current || startYRef.current === null) return;

    const touch = event.touches?.[0];

    if (!touch) return;

    const difference = touch.clientY - startYRef.current;

    if (difference <= 0) {
      setDragOffset(0);
      return;
    }

    setDragOffset(Math.min(difference, 220));
  };

  const handleTouchEnd = () => {
    isDraggingRef.current = false;
    startYRef.current = null;

    if (dragOffset > 95) {
      closeModal();
      return;
    }

    setDragOffset(0);
  };

  const handleBackdropClick = () => {
    closeModal();
  };

  const decreaseQuantity = () => {
    setQuantity((current) => {
      if (current === "" || current === null) {
        return 1;
      }

      return Math.max(1, Number(current) - 1);
    });
  };

  const increaseQuantity = () => {
    setQuantity((current) => {
      if (current === "" || current === null) {
        return 1;
      }

      return Math.min(99, Number(current) + 1);
    });
  };

  const handleQuantityInput = (event) => {
    const rawValue = event.target.value;

    if (rawValue === "") {
      setQuantity("");
      return;
    }

    const parsedValue = Number.parseInt(rawValue, 10);

    if (Number.isNaN(parsedValue)) return;

    setQuantity(Math.min(99, Math.max(1, parsedValue)));
  };

  const handleContact = () => {
    setShowErrors(true);

    if (!isLocationValid) {
      locationInputRef.current?.focus();
      return;
    }

    if (!isSofaQuantityValid || !isCarpetQuantityValid) {
      return;
    }

    const normalizedQuantity = isSofa
      ? sofaQuantityNumber
      : isCarpet && carpetQuantityNumber !== null
        ? carpetQuantityNumber
        : null;

    onOrderNow?.({
      serviceId: selected.id,
      location: normalizedLocation,
      quantity: normalizedQuantity,
      carpetPriceOption:
        isCarpet && carpetPriceOption ? carpetPriceOption : null,
    });
  };

  const renderOrderButton = (isMobile = false) => (
    <button
      type="button"
      onClick={handleContact}
      className={[
        "flex min-h-13 w-full items-center justify-center gap-2.5",
        "rounded-2xl px-5 py-3.5",
        "text-[15px] font-black text-white sm:text-base",
        "transition-all duration-200",
        "focus-visible:outline-none focus-visible:ring-4",
        isFormValid
          ? [
              "bg-emerald-700",
              "shadow-[0_8px_22px_rgba(4,120,87,0.18)]",
              "hover:bg-emerald-800",
              "active:scale-[0.98]",
              "focus-visible:ring-emerald-100",
            ].join(" ")
          : [
              "cursor-pointer bg-slate-400",
              "shadow-sm",
              "focus-visible:ring-slate-200",
            ].join(" "),
        isMobile ? "" : "hover:shadow-[0_12px_30px_rgba(4,120,87,0.23)]",
      ].join(" ")}
      aria-disabled={!isFormValid}
    >
      <MessageCircle size={21} strokeWidth={2.4} />
      <span>{contactText}</span>
    </button>
  );

  const carpetOptions = [
    {
      value: CARPET_PRICE_OPTIONS.measurements,
      title: measurementsTitle,
      description: measurementsDescription,
    },
    {
      value: CARPET_PRICE_OPTIONS.meterPrice,
      title: meterPriceTitle,
      description: meterPriceDescription,
    },
    {
      value: CARPET_PRICE_OPTIONS.onSiteMeasure,
      title: onSiteMeasureTitle,
      description: onSiteMeasureDescription,
    },
  ];

  return (
    <div
      className="fixed inset-0 z-[70]"
      role="dialog"
      aria-modal="true"
      aria-labelledby="service-modal-title"
      dir={dir}
    >
      <button
        type="button"
        onClick={handleBackdropClick}
        aria-label={closeText}
        className={[
          "absolute inset-0 bg-slate-950/50 backdrop-blur-[2px]",
          "transition-opacity duration-300",
          isVisible && !isClosing ? "opacity-100" : "opacity-0",
        ].join(" ")}
      />

      <div className="absolute inset-x-0 bottom-0 flex justify-center sm:inset-0 sm:items-center sm:p-6">
        <section
          onClick={(event) => event.stopPropagation()}
          className={[
            "relative flex w-full flex-col overflow-hidden bg-white",
            "rounded-t-[30px] shadow-[0_-20px_60px_rgba(15,23,42,0.22)]",
            "sm:max-h-[840px] sm:max-w-2xl sm:rounded-[30px]",
            "sm:shadow-[0_25px_80px_rgba(15,23,42,0.24)]",
            "transition-transform duration-300 ease-out",
          ].join(" ")}
          style={{
            height: "min(92dvh, 880px)",
            transform:
              isVisible && !isClosing
                ? `translateY(${dragOffset}px)`
                : "translateY(100%)",
          }}
        >
          <div
            className="relative shrink-0 touch-none px-4 pb-3 pt-3 sm:hidden"
            onTouchStart={handleTouchStart}
            onTouchMove={handleTouchMove}
            onTouchEnd={handleTouchEnd}
          >
            <div className="mx-auto h-1.5 w-12 rounded-full bg-slate-300" />

            <p className="mt-2 text-center text-[11px] font-bold text-slate-400">
              {swipeHint}
            </p>
          </div>

          <div className="relative h-[190px] shrink-0 overflow-hidden sm:h-[250px]">
            <img
              src={details?.image || selected.image}
              alt={title}
              className="h-full w-full object-cover"
            />

            <div className="absolute inset-0 bg-gradient-to-t from-slate-950/75 via-slate-900/15 to-transparent" />

            <button
              type="button"
              onClick={closeModal}
              aria-label={closeText}
              className={[
                "absolute top-4 flex h-11 w-11 items-center justify-center",
                "rounded-full border border-white/30 bg-white/90",
                "text-slate-800 shadow-lg backdrop-blur",
                "transition hover:bg-white active:scale-95",
                dir === "rtl" ? "left-4" : "right-4",
              ].join(" ")}
            >
