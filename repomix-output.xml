    { value: "complaint", labelAr: "ملاحظة", labelEn: "Note", labelHe: "הערה" },
    { value: "other", labelAr: "أخرى", labelEn: "Other", labelHe: "אחר" },
  ];

  const getLabel = (item) => {
    if (lang === "he") return item.labelHe;
