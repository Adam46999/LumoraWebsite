// src/components/services/Services.jsx
import React, { useEffect, useMemo, useState } from "react";
import { services } from "./servicesData";
import ServiceCard from "./ServiceCard";
import ServiceModal from "./ServiceModal";
import { useLanguage } from "../../context/LanguageContext";

const WHATSAPP_NUMBERS = {
  sofa: "972502727724",
  carpet: "972543075619",
  carSeats: "972502727724",
  glass: "972502727724",
};

const DEFAULT_WHATSAPP_NUMBER = "972502727724";

const getText = (lang, values) => {
  if (lang === "he") return values.he;
  if (lang === "en") return values.en;

  return values.ar;
};

const getCarpetPriceOptionText = (lang, option) => {
  const options = {
    measurements: {
      ar: "أعرف القياسات وسأرسل طول وعرض كل سجادة.",
      he: "אני יודע/ת את המידות ואשלח אורך ורוחב של כל שטיח.",
      en: "I know the measurements and will send the length and width of each carpet.",
    },

    meterPrice: {
      ar: "أريد معرفة سعر المتر.",
      he: "אני רוצה לדעת מה המחיר למטר.",
      en: "I would like to know the price per meter.",
    },

    onSiteMeasure: {
      ar: "لا أعرف القياسات وأحتاج قياس السجاد في الموقع.",
      he: "אני לא יודע/ת את המידות וצריך/ה מדידה במקום.",
      en: "I do not know the measurements and need the carpets measured at my location.",
    },
  };

  const selectedOption = options[option];

  if (!selectedOption) return "";

  return getText(lang, selectedOption);
};

export default function Services() {
  const { t, lang, isRTL } = useLanguage();

  const [selected, setSelected] = useState(null);
  const [titleVisible, setTitleVisible] = useState(false);

  useEffect(() => {
    const element = document.getElementById("services-title");

    if (!element) return undefined;

    if (!("IntersectionObserver" in window)) {
      setTitleVisible(true);
      return undefined;
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) return;

        setTitleVisible(true);
        observer.unobserve(entry.target);
      },
      {
        threshold: 0.25,
      },
    );

    observer.observe(element);

    return () => {
      observer.disconnect();
    };
  }, []);

  const serviceList = useMemo(() => services, []);

  const getServiceTitle = (service) => {
    return t?.[service.titleKey] || service.id;
  };

  const getWhatsAppNumber = (serviceId) => {
    return WHATSAPP_NUMBERS[serviceId] || DEFAULT_WHATSAPP_NUMBER;
  };

  const buildSofaMessage = ({ serviceTitle, location, quantity }) => {
    return getText(lang, {
      ar: [
        `مرحبًا، أريد طلب خدمة ${serviceTitle}.`,
        `البلدة: ${location}`,
        `عدد المقاعد: ${quantity}`,
        "سأرسل صور الكنب أو فرشات النوم الآن لتحديد السعر والموعد.",
      ].join("\n"),

      he: [
        `שלום, אני רוצה להזמין שירות ${serviceTitle}.`,
        `יישוב: ${location}`,
        `מספר מושבים: ${quantity}`,
        "אשלח עכשיו תמונות של הספות או המזרנים לצורך קביעת המחיר והמועד.",
      ].join("\n"),

      en: [
        `Hello, I would like to request ${serviceTitle}.`,
        `Town: ${location}`,
        `Number of seats: ${quantity}`,
        "I will send photos of the sofas or mattresses now so the price and appointment can be confirmed.",
      ].join("\n"),
    });
  };

  const buildCarpetMessage = ({
    serviceTitle,
    location,
    quantity,
    carpetPriceOption,
  }) => {
    const pricingText = getCarpetPriceOptionText(lang, carpetPriceOption);

    const messages = {
      ar: [
        `مرحبًا، أريد طلب خدمة ${serviceTitle} في البيت.`,
        `البلدة: ${location}`,
      ],

      he: [
        `שלום, אני רוצה להזמין שירות ${serviceTitle} בבית.`,
        `יישוב: ${location}`,
      ],

      en: [
        `Hello, I would like to request ${serviceTitle} at home.`,
        `Town: ${location}`,
      ],
    };

    if (quantity) {
      messages.ar.push(`عدد السجاد: ${quantity}`);
      messages.he.push(`מספר שטיחים: ${quantity}`);
      messages.en.push(`Number of carpets: ${quantity}`);
    }

    if (pricingText) {
      messages.ar.push(`طريقة معرفة السعر: ${pricingText}`);
      messages.he.push(`אופן קבלת המחיר: ${pricingText}`);
      messages.en.push(`Pricing request: ${pricingText}`);
    }

    messages.ar.push("ممكن تفاصيل أكثر عن الخدمة؟");
    messages.he.push("אפשר לקבל פרטים נוספים על השירות?");
    messages.en.push("Could you provide more details about the service?");

    return getText(lang, {
      ar: messages.ar.join("\n"),
      he: messages.he.join("\n"),
      en: messages.en.join("\n"),
    });
  };

  const buildGeneralMessage = ({ serviceTitle, location }) => {
    return getText(lang, {
      ar: [
        `مرحبًا، أريد طلب خدمة ${serviceTitle} في موقعي.`,
        `البلدة: ${location}`,
        "سأرسل الصور والتفاصيل اللازمة عبر واتساب.",
      ].join("\n"),

      he: [
        `שלום, אני רוצה להזמין שירות ${serviceTitle} במיקום שלי.`,
        `יישוב: ${location}`,
        "אשלח תמונות ופרטים נוספים דרך WhatsApp.",
      ].join("\n"),

      en: [
        `Hello, I would like to request ${serviceTitle} at my location.`,
        `Town: ${location}`,
        "I will send the necessary photos and details through WhatsApp.",
      ].join("\n"),
    });
  };

  const buildMessage = (service, orderDetails = null) => {
    const serviceTitle = getServiceTitle(service);

    const location = orderDetails?.location?.trim() || "";

    const quantity =
      orderDetails?.quantity !== null &&
      orderDetails?.quantity !== undefined &&
      orderDetails?.quantity !== ""
        ? Number(orderDetails.quantity)
        : null;

    const carpetPriceOption = orderDetails?.carpetPriceOption || null;

    if (service.id === "sofa") {
      return buildSofaMessage({
        serviceTitle,
        location,
        quantity,
      });
    }

    if (service.id === "carpet") {
      return buildCarpetMessage({
        serviceTitle,
        location,
        quantity,
        carpetPriceOption,
      });
    }

    return buildGeneralMessage({
      serviceTitle,
      location,
    });
  };

  const openWhatsApp = (service, orderDetails = null) => {
    if (!service) return;

    const phone = getWhatsAppNumber(service.id);
    const message = buildMessage(service, orderDetails);

    const url = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;

    window.open(url, "_blank", "noopener,noreferrer");
  };

  const handleDirectContact = (service) => {
    if (!service) return;

    setSelected(service);
  };

  const sectionBadge = getText(lang, {
    ar: "خدمات تنظيف في بيت الزبون",
    he: "שירותי ניקיון בבית הלקוח",
    en: "Cleaning services at your location",
  });

  const sectionTitle = getText(lang, {
    ar: "اختر الخدمة المناسبة لك",
    he: "בחרו את השירות המתאים לכם",
    en: "Choose the right service for you",
  });

  const sectionSubtitle = getText(lang, {
    ar: "جميع الخدمات تتم في موقعك في مناطق الشمال والمركز. اختر الخدمة وأدخل التفاصيل المناسبة للمتابعة عبر واتساب.",
    he: "כל השירותים מתבצעים אצלכם באזורי הצפון והמרכז. בחרו שירות ומלאו את הפרטים המתאימים להמשך ב-WhatsApp.",
    en: "All services are provided at your location across the north and center. Choose a service and enter the relevant details to continue through WhatsApp.",
  });

  return (
    <>
      <section
        id="services"
        className="relative overflow-hidden bg-gradient-to-b from-white via-slate-50/70 to-white px-4 py-14 sm:px-6 sm:py-18 lg:px-8 lg:py-20"
        dir={isRTL ? "rtl" : "ltr"}
      >
        <div className="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-slate-200 to-transparent" />

        <div className="mx-auto max-w-[1500px]">
          <div
            id="services-title"
            className={[
              "mx-auto mb-8 max-w-3xl text-center sm:mb-10",
              "transition-all duration-700 ease-out",
              titleVisible
                ? "translate-y-0 opacity-100"
                : "translate-y-3 opacity-0",
            ].join(" ")}
          >
            <div className="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-extrabold text-slate-700 shadow-sm">
              <span className="h-2 w-2 rounded-full bg-emerald-700" />
              <span>{sectionBadge}</span>
            </div>

            <h2 className="mt-5 text-[clamp(26px,7vw,42px)] font-black leading-tight tracking-tight text-slate-950">
              {sectionTitle}
            </h2>

            <p className="mx-auto mt-3 max-w-2xl text-[15px] font-medium leading-7 text-slate-600 sm:text-base">
              {sectionSubtitle}
            </p>
          </div>

          <div className="grid grid-cols-1 gap-5 sm:grid-cols-2 sm:gap-6 xl:grid-cols-4 xl:gap-5">
            {serviceList.map((service, index) => (
              <div
                key={service.id}
                className="h-full"
                style={{
                  transitionDelay: `${Math.min(index, 4) * 80}ms`,
                }}
              >
                <ServiceCard
                  id={service.id}
                  icon={service.icon}
                  titleKey={service.titleKey}
                  descriptionKey={service.descriptionKey}
                  image={service.image}
                  priority={service.priority}
                  onClick={() => setSelected(service)}
                  onBook={() => handleDirectContact(service)}
                />
              </div>
            ))}
          </div>
        </div>
      </section>

      <ServiceModal
        isOpen={Boolean(selected)}
        selected={selected}
        onClose={() => setSelected(null)}
        onOrderNow={(orderDetails) => {
          const currentService = selected;

          setSelected(null);

          window.setTimeout(() => {
            openWhatsApp(currentService, orderDetails);
          }, 150);
        }}
      />
    </>
  );
}
</file>

