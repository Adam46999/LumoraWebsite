      </label>

      <div id={id} className="flex flex-wrap gap-2" dir={isRTL ? "rtl" : "ltr"}>
        {items.map((item) => {
          const active = value === item.value;
          return (
            <button
              key={item.value}
              type="button"
              onClick={() => onChange({ target: { value: item.value } })}
