              <div className="mt-6 rounded-[24px] border border-emerald-100 bg-emerald-50/45 p-4 sm:p-5">
                <h3 className="text-lg font-black text-slate-950">
                  {orderDetailsTitle}
                </h3>

                <p className="mt-1 text-sm font-medium leading-6 text-slate-600">
                  {orderDetailsSubtitle}
                </p>

                <div className="mt-5">
                  <div className="mb-2 flex items-center justify-between gap-3">
                    <label
                      htmlFor="service-location"
                      className="block text-sm font-black text-slate-800"
                    >
                      {locationLabel}
                    </label>

                    <span className="rounded-full bg-red-50 px-2.5 py-1 text-[11px] font-black text-red-700">
                      {locationRequired}
                    </span>
                  </div>

                  <div className="relative">
                    <MapPin
                      size={19}
                      className={[
                        "pointer-events-none absolute top-1/2 -translate-y-1/2 text-slate-400",
                        dir === "rtl" ? "right-4" : "left-4",
                      ].join(" ")}
                    />

                    <input
                      ref={locationInputRef}
                      id="service-location"
                      type="text"
                      value={location}
                      onChange={(event) => {
                        setLocation(event.target.value);
                      }}
                      placeholder={locationPlaceholder}
                      autoComplete="address-level2"
                      className={[
                        "h-13 w-full rounded-2xl border bg-white text-[16px]",
                        "font-bold text-slate-950 outline-none transition",
                        "placeholder:font-medium placeholder:text-slate-400",
                        "focus:ring-4",
                        dir === "rtl" ? "pr-12 pl-4" : "pl-12 pr-4",
                        showErrors && !isLocationValid
                          ? "border-red-400 focus:border-red-500 focus:ring-red-100"
                          : "border-slate-200 focus:border-emerald-500 focus:ring-emerald-100",
                      ].join(" ")}
                    />
                  </div>

                  {showErrors && !isLocationValid ? (
                    <p className="mt-2 text-sm font-bold text-red-600">
                      {locationError}
                    </p>
                  ) : (
                    <p className="mt-2 text-xs font-semibold leading-5 text-slate-500">
                      {locationHint}
                    </p>
                  )}
                </div>

                {showsQuantity ? (
                  <div className="mt-5">
                    <div className="mb-2 flex items-center justify-between gap-3">
                      <label
                        htmlFor="service-quantity"
                        className="block text-sm font-black text-slate-800"
                      >
                        {quantityLabel}
                      </label>

                      <span
                        className={[
                          "rounded-full px-2.5 py-1 text-[11px] font-black",
                          isSofa
                            ? "bg-red-50 text-red-700"
                            : "bg-slate-100 text-slate-600",
                        ].join(" ")}
                      >
                        {isSofa ? locationRequired : optionalText}
                      </span>
                    </div>

                    <div className="flex items-center gap-3">
                      <button
                        type="button"
                        onClick={decreaseQuantity}
                        disabled={quantity !== "" && Number(quantity) <= 1}
                        className={[
                          "flex h-13 w-13 shrink-0 items-center justify-center",
                          "rounded-2xl border border-slate-200 bg-white",
                          "text-slate-800 transition",
                          "hover:border-emerald-300 hover:bg-emerald-50",
                          "active:scale-95",
                          "disabled:cursor-not-allowed disabled:opacity-40",
                        ].join(" ")}
                        aria-label={getText(lang, {
                          ar: "تقليل العدد",
                          he: "הפחתת הכמות",
                          en: "Decrease quantity",
                        })}
                      >
                        <Minus size={20} strokeWidth={2.5} />
                      </button>

                      <input
                        id="service-quantity"
                        type="number"
                        min="1"
                        max="99"
                        inputMode="numeric"
                        value={quantity}
                        onChange={handleQuantityInput}
                        onBlur={() => {
                          if (isSofa && (!quantity || Number(quantity) < 1)) {
                            setQuantity(1);
                          }
                        }}
                        placeholder={isCarpet ? optionalText : ""}
                        className={[
                          "h-13 min-w-0 flex-1 rounded-2xl",
                          "border bg-white px-4",
                          "text-center text-lg font-black text-slate-950",
                          "outline-none transition",
                          "placeholder:text-sm placeholder:font-bold placeholder:text-slate-400",
                          showErrors && !isSofaQuantityValid
                            ? "border-red-400 focus:border-red-500 focus:ring-4 focus:ring-red-100"
                            : "border-slate-200 focus:border-emerald-500 focus:ring-4 focus:ring-emerald-100",
                        ].join(" ")}
                      />

                      <button
                        type="button"
                        onClick={increaseQuantity}
                        disabled={quantity !== "" && Number(quantity) >= 99}
                        className={[
                          "flex h-13 w-13 shrink-0 items-center justify-center",
                          "rounded-2xl border border-slate-200 bg-white",
                          "text-slate-800 transition",
                          "hover:border-emerald-300 hover:bg-emerald-50",
                          "active:scale-95",
                          "disabled:cursor-not-allowed disabled:opacity-40",
                        ].join(" ")}
                        aria-label={getText(lang, {
                          ar: "زيادة العدد",
                          he: "הגדלת הכמות",
                          en: "Increase quantity",
                        })}
                      >
                        <Plus size={20} strokeWidth={2.5} />
                      </button>
                    </div>

                    {showErrors && !isSofaQuantityValid ? (
                      <p className="mt-2 text-sm font-bold text-red-600">
                        {sofaQuantityError}
                      </p>
                    ) : (
                      <p className="mt-2 text-xs font-semibold leading-5 text-slate-500">
                        {quantityHint}
                      </p>
                    )}
                  </div>
                ) : null}

                {isCarpet ? (
                  <div className="mt-6">
                    <div className="flex items-start gap-3">
                      <div className="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-white text-emerald-800 shadow-sm">
                        <Ruler size={20} strokeWidth={2.3} />
                      </div>

                      <div className="min-w-0 flex-1">
                        <div className="flex flex-wrap items-center justify-between gap-2">
                          <h4 className="text-sm font-black text-slate-950">
                            {carpetPricingTitle}
                          </h4>

                          <span className="rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-black text-slate-600">
                            {optionalText}
                          </span>
                        </div>

                        <p className="mt-1 text-xs font-semibold leading-5 text-slate-500">
                          {carpetPricingSubtitle}
                        </p>
                      </div>
                    </div>

                    <div className="mt-4 grid gap-3">
                      {carpetOptions.map((option) => {
                        const isSelected = carpetPriceOption === option.value;

                        return (
                          <button
                            key={option.value}
                            type="button"
                            onClick={() => {
                              setCarpetPriceOption((current) =>
                                current === option.value ? "" : option.value,
                              );
                            }}
                            className={[
                              "w-full rounded-2xl border p-4 text-start",
                              "transition-all duration-200",
                              "active:scale-[0.99]",
                              isSelected
                                ? "border-emerald-500 bg-emerald-50 shadow-sm"
                                : "border-slate-200 bg-white hover:border-emerald-200",
                            ].join(" ")}
                          >
                            <div className="flex items-start gap-3">
                              <span
                                className={[
                                  "mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full border-2",
                                  isSelected
                                    ? "border-emerald-600 bg-emerald-600"
                                    : "border-slate-300 bg-white",
                                ].join(" ")}
                              >
                                {isSelected ? (
                                  <span className="h-2 w-2 rounded-full bg-white" />
                                ) : null}
                              </span>

                              <span>
                                <span className="block text-sm font-black text-slate-950">
                                  {option.title}
                                </span>

                                <span className="mt-1 block text-xs font-medium leading-5 text-slate-600">
                                  {option.description}
                                </span>
                              </span>
                            </div>
                          </button>
                        );
                      })}
                    </div>

                    {carpetPriceOption ? (
                      <button
                        type="button"
                        onClick={() => setCarpetPriceOption("")}
                        className="mt-3 text-xs font-black text-slate-500 underline underline-offset-4 transition hover:text-slate-800"
                      >
                        {clearChoiceText}
                      </button>
                    ) : null}
                  </div>
                ) : null}

                <div className="mt-5 rounded-2xl border border-slate-200 bg-white px-4 py-3">
                  <p className="text-xs font-bold leading-5 text-slate-600">
                    {isSofa
                      ? sofaPhotosHint
                      : isCarpet
                        ? carpetHint
                        : generalHint}
                  </p>
                </div>
              </div>

              <div className="mt-6 hidden sm:block">
                {renderOrderButton(false)}
              </div>
            </div>
          </div>

          <div className="absolute inset-x-0 bottom-0 border-t border-slate-200 bg-white/95 px-4 pb-[calc(12px+env(safe-area-inset-bottom))] pt-3 backdrop-blur sm:hidden">
            {renderOrderButton(true)}
          </div>
        </section>
      </div>
    </div>
  );
}
