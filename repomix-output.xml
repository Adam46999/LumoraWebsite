// src/components/services/ServiceCard.jsx
import React, { useEffect, useRef, useState } from "react";
import {
  ArrowLeft,
  ArrowRight,
  Car,
  Clock3,
  Layers,
  MessageCircle,
  Sofa,
  Sparkles,
} from "lucide-react";
import { useLanguage } from "../../context/LanguageContext";

const iconMap = {
  couch: Sofa,
  car: Car,
  "layer-group": Layers,
  sparkles: Sparkles,
};

const getLearnMoreText = (lang) => {
  if (lang === "he") return "למידע נוסף";
  if (lang === "en") return "Learn more";

  return "اعرف أكثر";
};

const getWhatsAppText = (lang) => {
  if (lang === "he") return "יצירת קשר ב-WhatsApp";
  if (lang === "en") return "Contact via WhatsApp";

  return "تواصل عبر واتساب";
};

const getUnavailableText = (lang) => {
  if (lang === "he") return "לא זמין כרגע";
  if (lang === "en") return "Currently unavailable";

  return "غير متاح حاليًا";
};

const getUnavailableAriaText = (lang, title) => {
  if (lang === "he") {
    return `${title} - השירות אינו זמין כרגע`;
  }

  if (lang === "en") {
    return `${title} - currently unavailable`;
  }

  return `${title} - الخدمة غير متاحة حاليًا`;
};

export default function ServiceCard({
  id,
  icon,
  titleKey,
  descriptionKey,
  image,
  priority = "secondary",
  onClick,
  onBook,
}) {
  const { t, lang, isRTL } = useLanguage();

  const [visible, setVisible] = useState(false);
  const cardRef = useRef(null);

  const Icon = iconMap[icon] || Sparkles;
  const isPrimary = priority === "primary";

  const isUnavailable = id === "glass" || id === "carSeats";

  const title = t?.[titleKey] || titleKey;
  const description = t?.[descriptionKey] || descriptionKey;

  const learnMoreText = getLearnMoreText(lang);
  const whatsappText = getWhatsAppText(lang);
  const unavailableText = getUnavailableText(lang);

  useEffect(() => {
    const element = cardRef.current;

    if (!element) return undefined;

    if (!("IntersectionObserver" in window)) {
      setVisible(true);
      return undefined;
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) return;

        setVisible(true);
        observer.unobserve(entry.target);
      },
      {
        threshold: 0.12,
      },
    );

    observer.observe(element);

    return () => {
      observer.disconnect();
    };
  }, []);

  const openDetails = () => {
    onClick?.();
  };

  const handleCardKeyDown = (event) => {
    if (event.key !== "Enter" && event.key !== " ") return;

    event.preventDefault();
    openDetails();
  };

  const handleBook = (event) => {
    event.stopPropagation();

    if (isUnavailable) return;

    onBook?.();
  };

  return (
    <article
      ref={cardRef}
      role="button"
      tabIndex={0}
      aria-label={
        isUnavailable
          ? getUnavailableAriaText(lang, title)
          : `${title} - ${learnMoreText}`
      }
      data-service-id={id}
      data-service-priority={priority}
      data-service-available={isUnavailable ? "false" : "true"}
      onClick={openDetails}
      onKeyDown={handleCardKeyDown}
      className={[
        "group relative flex h-full cursor-pointer flex-col overflow-hidden",
        "rounded-[26px] border bg-white text-start",
        "transition-all duration-500 ease-out",
        "focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-sky-200",
        "active:scale-[0.99]",
        isPrimary
          ? "border-sky-100 shadow-[0_14px_38px_rgba(15,23,42,0.10)]"
          : "border-slate-200 shadow-[0_10px_28px_rgba(15,23,42,0.07)]",
        isUnavailable
          ? [
              "border-slate-200 bg-slate-50/80",
              "shadow-[0_8px_24px_rgba(15,23,42,0.05)]",
              "hover:-translate-y-0.5",
              "hover:shadow-[0_12px_32px_rgba(15,23,42,0.08)]",
            ].join(" ")
          : [
              "hover:-translate-y-1",
              "hover:shadow-[0_20px_48px_rgba(15,23,42,0.13)]",
            ].join(" "),
        visible ? "translate-y-0 opacity-100" : "translate-y-5 opacity-0",
      ].join(" ")}
    >
      <div
        className={[
          "relative w-full overflow-hidden bg-slate-100",
          isPrimary
            ? "h-[210px] sm:h-[220px] lg:h-[205px]"
            : "h-[175px] sm:h-[190px] lg:h-[185px]",
        ].join(" ")}
      >
        <img
          src={image}
          alt={title}
          loading="lazy"
          className={[
            "h-full w-full object-cover",
            "transition-all duration-700 ease-out",
            isUnavailable
              ? "scale-[1.01] saturate-[0.65] brightness-[0.82]"
              : "group-hover:scale-[1.045]",
          ].join(" ")}
        />

        <div
          className={[
            "absolute inset-0",
            isUnavailable
              ? "bg-slate-900/25"
              : "bg-gradient-to-t from-slate-950/55 via-slate-900/5 to-transparent",
          ].join(" ")}
        />

        {isUnavailable ? (
          <div
            className={[
              "absolute top-3 z-10 inline-flex items-center gap-1.5",
              "rounded-full border border-white/30 bg-slate-950/80",
              "px-3 py-2 text-xs font-black text-white shadow-lg",
              "backdrop-blur-md",
              isRTL ? "right-3" : "left-3",
            ].join(" ")}
          >
            <Clock3 size={15} strokeWidth={2.5} />
            <span>{unavailableText}</span>
          </div>
        ) : null}

        <div
          className={[
            "absolute bottom-3 flex h-11 w-11 items-center justify-center",
            "rounded-2xl border border-white/30 bg-white/90",
            "shadow-lg backdrop-blur",
            isUnavailable ? "text-slate-500" : "text-sky-700",
            isRTL ? "right-3" : "left-3",
          ].join(" ")}
          aria-hidden="true"
        >
          <Icon size={21} strokeWidth={2.2} />
        </div>
      </div>

      <div
        className={[
          "flex flex-1 flex-col",
          isPrimary ? "p-5 sm:p-6" : "p-5",
        ].join(" ")}
      >
        <div className="flex items-start justify-between gap-3">
          <h3
            className={[
              "font-black tracking-tight",
              isUnavailable ? "text-slate-700" : "text-slate-950",
              isPrimary ? "text-[22px] sm:text-2xl" : "text-xl sm:text-[22px]",
            ].join(" ")}
          >
            {title}
          </h3>
        </div>

        <p
          className={[
            "mt-2 min-h-[48px] text-[15px] font-medium leading-6",
            isUnavailable ? "text-slate-500" : "text-slate-600",
          ].join(" ")}
          style={{
            display: "-webkit-box",
            WebkitBoxOrient: "vertical",
            WebkitLineClamp: 2,
            overflow: "hidden",
          }}
        >
          {description}
        </p>

        <div className="mt-auto pt-5">
          <button
            type="button"
            onClick={handleBook}
            disabled={isUnavailable}
            aria-disabled={isUnavailable}
            className={[
              "flex min-h-12 w-full items-center justify-center gap-2.5",
              "rounded-2xl px-4 py-3",
              "text-[15px] font-black",
              "transition-all duration-200",
              "focus-visible:outline-none focus-visible:ring-4",
              isUnavailable
                ? [
                    "cursor-not-allowed border border-slate-200",
                    "bg-slate-200 text-slate-500 shadow-none",
                    "focus-visible:ring-slate-100",
                  ].join(" ")
                : [
                    "bg-emerald-700 text-white",
                    "shadow-[0_8px_20px_rgba(4,120,87,0.18)]",
                    "hover:bg-emerald-800",
                    "hover:shadow-[0_10px_24px_rgba(4,120,87,0.22)]",
                    "active:scale-[0.98]",
                    "focus-visible:ring-emerald-100",
                  ].join(" "),
            ].join(" ")}
            aria-label={
              isUnavailable
                ? getUnavailableAriaText(lang, title)
                : `${whatsappText} - ${title}`
            }
          >
            {isUnavailable ? (
              <Clock3 size={20} strokeWidth={2.4} />
            ) : (
              <MessageCircle size={20} strokeWidth={2.4} />
            )}

            <span>{isUnavailable ? unavailableText : whatsappText}</span>
          </button>

          <button
            type="button"
            onClick={(event) => {
              event.stopPropagation();
              openDetails();
            }}
            className={[
              "mx-auto mt-3 flex min-h-10 items-center justify-center gap-1.5",
              "rounded-xl px-3 py-2",
              "text-sm font-extrabold",
              "transition-colors duration-200",
              "focus-visible:outline-none focus-visible:ring-4",
              isUnavailable
                ? [
                    "text-slate-500",
                    "hover:bg-slate-100 hover:text-slate-700",
                    "focus-visible:ring-slate-100",
                  ].join(" ")
                : [
                    "text-slate-600",
                    "hover:bg-slate-100 hover:text-sky-700",
                    "focus-visible:ring-sky-100",
                  ].join(" "),
            ].join(" ")}
          >
            <span>{learnMoreText}</span>

            {isRTL ? (
              <ArrowLeft size={16} strokeWidth={2.3} />
            ) : (
              <ArrowRight size={16} strokeWidth={2.3} />
            )}
          </button>
        </div>
      </div>
    </article>
  );
}
