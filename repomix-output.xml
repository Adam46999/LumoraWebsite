  { type: "product", title: "بيع منتج" },
  { type: "carpet", title: "سجاد" },
];

export const LS_RECENT_PRESETS = "admin_daily_recent_presets_v1";
export const LS_LAST_ENTRY = "admin_daily_last_entry_v1";

