            </div>
          </div>

          <div className="min-h-0 flex-1 overflow-y-auto overscroll-contain">
            <div className="px-5 pb-32 pt-5 sm:px-7 sm:pb-7 sm:pt-6">
              {description ? (
                <p className="text-[15px] font-medium leading-7 text-slate-600 sm:text-base">
                  {description}
                </p>
              ) : null}

              <div className="mt-6 rounded-[24px] border border-slate-200 bg-slate-50/70 p-4 sm:p-5">
                <div className="flex items-center gap-2">
                  <div className="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-800">
                    <CheckCircle2 size={20} strokeWidth={2.3} />
                  </div>

                  <h3 className="text-lg font-black text-slate-950">
                    {includesTitle}
                  </h3>
                </div>

                <ul className="mt-4 grid gap-3">
                  {includes.length > 0 ? (
                    includes.map((item, index) => (
                      <li
                        key={`${item}-${index}`}
                        className="flex items-start gap-3"
                      >
                        <span className="mt-2 h-2 w-2 shrink-0 rounded-full bg-emerald-700" />

                        <span className="text-sm font-medium leading-6 text-slate-700 sm:text-[15px]">
