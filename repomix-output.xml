                "h-10 px-4 rounded-full border text-sm font-semibold transition",
                active
                  ? "bg-blue-50 text-blue-700 border-blue-200"
                  : "bg-white text-gray-700 border-gray-200 hover:border-blue-200 hover:bg-blue-50/60",
              ].join(" ")}
            >
              {getLabel(item)}
            </button>
          );
        })}
